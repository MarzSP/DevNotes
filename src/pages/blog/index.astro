---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

function toArray(v: unknown): string[] {
	if (Array.isArray(v)) return v as string[];
	if (typeof v === 'string' && v) return [v];
	return [];
}

function toClass(s: string): string {
	return s.toLowerCase().trim().replace(/\s+/g, '-').replace(/[^a-z0-9-_]/g, '');
}

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const rawFilters = posts.flatMap((p) => {
	const d = p.data as unknown as Record<string, unknown>;
	const tags = toArray(d.tags);
	if (tags.length) return tags;
	return toArray(d.theme);
});

const uniqueFilters = [...new Set(rawFilters.map((f) => f.trim()).filter(Boolean))];
const base = import.meta.env.BASE_URL;

const processedPosts = posts.map((post) => {
	const d = post.data as unknown as Record<string, unknown>;
	const tags = toArray(d.tags).length ? toArray(d.tags) : toArray(d.theme);
	const filters = tags.map(toClass);
	const firstTag = tags[0] ?? '';
	return { post, tags, filters, firstTag };
});
---

<!doctype html>
<html lang="en">
<head>
	<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	<style>
		main {
			width: 1200px;
			max-width: calc(100% - 2em);
			margin: 0 auto;
			padding: 3em 1em;
		}

		.layout {
			display: grid;
			grid-template-columns: 160px 1fr;
			gap: 3rem;
			align-items: start;
		}

		/* Sidebar */
		.sidebar {
			position: sticky;
			top: 2rem;
		}

		.sidebar-label {
			font-size: 0.7rem;
			font-weight: 600;
			text-transform: uppercase;
			letter-spacing: 0.1em;
			color: rgb(var(--gray));
			margin: 0 0 0.75rem 0;
		}

		.sidebar-filters {
			display: flex;
			flex-direction: column;
			gap: 0.15rem;
			list-style: none;
			margin: 0;
			padding: 0;
		}

		.sidebar-filters li button {
			-webkit-appearance: none;
			appearance: none;
			border: none;
			background: none;
			cursor: pointer;
			font: inherit;
			width: 100%;
			text-align: left;
			padding: 0.35rem 0.6rem;
			border-radius: 5px;
			font-size: 0.85rem;
			color: rgb(var(--gray));
			transition: background 0.12s, color 0.12s;
		}

		.sidebar-filters li button:hover {
			background: rgb(var(--gray-light));
			color: rgb(var(--black));
		}

		.sidebar-filters li button[aria-pressed="true"] {
			background: rgba(202, 138, 4, 0.1);
			color: #ca8a04;
			font-weight: 500;
		}

		/* Content area */
		.content-header {
			margin-bottom: 2rem;
			padding-bottom: 1.5rem;
			border-bottom: 1px solid rgb(var(--gray-light));
		}

		html.dark .content-header {
			border-bottom-color: #30363d;
		}

		.content-header h1 {
			font-size: 1.5rem;
			font-weight: 600;
			margin: 0 0 0.2rem 0;
			color: rgb(var(--black));
		}

		.content-header p {
			margin: 0;
			color: rgb(var(--gray));
			font-size: 0.875rem;
		}

		/* Grid */
		.grid {
			display: grid;
			grid-template-columns: repeat(2, 1fr);
			gap: 1px;
			background: rgb(var(--gray-light));
			border: 1px solid rgb(var(--gray-light));
			border-radius: 10px;
			overflow: hidden;
			list-style: none;
			margin: 0;
			padding: 0;
		}

		.card {
			background: #fff;
			padding: 1.5rem;
			display: flex;
			flex-direction: column;
			transition: background 0.15s;
		}

		.card a {
			text-decoration: none;
			display: flex;
			flex-direction: column;
			gap: 0.5rem;
			height: 100%;
		}

		.card:hover {
			background: #f6f8fa;
		}

		.card-meta {
			display: flex;
			align-items: center;
			gap: 0.5rem;
			font-size: 0.78rem;
			color: #ca8a04;
		}

		.card-meta .dot {
			width: 3px;
			height: 3px;
			border-radius: 50%;
			background: currentColor;
			flex-shrink: 0;
		}

		.card-tag {
			font-size: 0.72rem;
			font-weight: 500;
			text-transform: uppercase;
			letter-spacing: 0.06em;
		}

		.card-title {
			font-size: 1.05rem;
			font-weight: 600;
			color: rgb(var(--black));
			line-height: 1.35;
			margin: 0;
		}

		.card:hover .card-title {
			color: var(--accent);
		}

		.card-desc {
			font-size: 0.875rem;
			color: rgb(var(--gray));
			line-height: 1.55;
			margin: 0;
			display: -webkit-box;
			-webkit-line-clamp: 2;
			-webkit-box-orient: vertical;
			overflow: hidden;
		}

		.card-arrow {
			margin-top: auto;
			padding-top: 0.75rem;
			font-size: 0.8rem;
			color: rgb(var(--gray));
			display: flex;
			align-items: center;
			gap: 0.3rem;
			opacity: 0;
			transition: opacity 0.15s;
		}

		.card:hover .card-arrow {
			opacity: 1;
			color: var(--accent);
		}

		#no-results {
			color: rgb(var(--gray));
			margin-top: 1rem;
		}

		.hidden { display: none !important; }

		/* Dark mode */
		html.dark .grid {
			background: #30363d;
			border-color: #30363d;
		}

		html.dark .card {
			background: #0d1117;
		}

		html.dark .card:hover {
			background: #161b22;
		}

		html.dark .card-title {
			color: #e6edf3;
		}

		html.dark .card:hover .card-title {
			color: #58a6ff;
		}

		html.dark .card-arrow {
			color: #7d8590;
		}

		html.dark .card:hover .card-arrow {
			color: #58a6ff;
		}

		html.dark .content-header h1 {
			color: #f0f6fc;
		}

		html.dark .card-meta {
			color: #fbbf24;
		}

		html.dark .sidebar-filters li button {
			color: #7d8590;
		}

		html.dark .sidebar-filters li button:hover {
			background: #21262d;
			color: #e6edf3;
		}

		html.dark .sidebar-filters li button[aria-pressed="true"] {
			background: rgba(251, 191, 36, 0.1);
			color: #fbbf24;
		}

		/* Mobile: stack sidebar above grid */
		@media (max-width: 720px) {
			.layout {
				grid-template-columns: 1fr;
				gap: 1.5rem;
			}

			.sidebar {
				position: static;
			}

			.sidebar-filters {
				flex-direction: row;
				flex-wrap: wrap;
				gap: 0.4rem;
			}

			.sidebar-filters li button {
				width: auto;
				padding: 0.25rem 0.65rem;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 20px;
			}

			.grid {
				grid-template-columns: 1fr;
			}
		}
	</style>
</head>
<body>
<Header />
<main>
	<div class="content-header">
		<h1>All posts</h1>
		<p>{posts.length} articles on software engineering</p>
	</div>

	<div class="layout">

		<!-- Sidebar -->
		<aside class="sidebar">
			<p class="sidebar-label">Topics</p>
			<ul class="sidebar-filters" id="filters">
				<li>
					<button type="button" class="blog-filter-all" aria-pressed="true">All</button>
				</li>
				{uniqueFilters.map((f) => (
					<li>
						<button type="button" class="blog-filter" data-filter={toClass(f)} aria-pressed="false">
							{f}
						</button>
					</li>
				))}
			</ul>
		</aside>

		<!-- Main content -->
		<div class="content">
			<ul class="grid" id="blog-grid">
				{processedPosts.map(({ post, filters, firstTag }) => (
					<li class={['blog-card card', ...filters].join(' ')} data-filters={JSON.stringify(filters)}>
						<a href={`${base}blog/${post.id}/`}>
							<div class="card-meta">
								<FormattedDate date={post.data.pubDate} />
								{firstTag && <><span class="dot"></span><span class="card-tag">{firstTag}</span></>}
							</div>
							<h2 class="card-title">{post.data.title}</h2>
							{post.data.description && <p class="card-desc">{post.data.description}</p>}
							<span class="card-arrow">Read more →</span>
						</a>
					</li>
				))}
			</ul>

			<p id="no-results" class="hidden">No posts match this filter.</p>
		</div>
	</div>
</main>
<Footer />

<script is:inline>
	(function () {
		const params = new URLSearchParams(location.search);
		const preselect = params.get('tag') || params.get('theme') || '';

		const allBtn = document.querySelector('.blog-filter-all');
		const filterBtns = Array.from(document.querySelectorAll('.blog-filter'));
		const cards = Array.from(document.querySelectorAll('#blog-grid .blog-card'));
		const noResults = document.getElementById('no-results');

		function updateEmptyState() {
			const anyVisible = cards.some(c => !c.classList.contains('hidden'));
			noResults?.classList.toggle('hidden', anyVisible);
		}

		function showAll() {
			cards.forEach(c => c.classList.remove('hidden'));
			filterBtns.forEach(b => b.setAttribute('aria-pressed', 'false'));
			allBtn?.setAttribute('aria-pressed', 'true');
			updateEmptyState();
		}

		function applyFilter(filterClass) {
			if (!filterClass) return showAll();
			allBtn?.setAttribute('aria-pressed', 'false');
			filterBtns.forEach(b => b.setAttribute('aria-pressed', b.dataset.filter === filterClass ? 'true' : 'false'));
			cards.forEach(card => {
				const list = JSON.parse(card.dataset.filters || '[]');
				card.classList.toggle('hidden', !list.includes(filterClass));
			});
			updateEmptyState();
		}

		allBtn?.addEventListener('click', () => {
			const next = new URL(location.href);
			next.searchParams.delete('tag');
			next.searchParams.delete('theme');
			history.replaceState({}, '', next.toString());
			showAll();
		});

		filterBtns.forEach(btn => {
			btn.addEventListener('click', () => {
				const f = btn.dataset.filter;
				const next = new URL(location.href);
				next.searchParams.delete('theme');
				next.searchParams.set('tag', f);
				history.replaceState({}, '', next.toString());
				applyFilter(f);
			});
		});

		if (preselect) {
			const safe = preselect.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-_]/g, '');
			applyFilter(safe);
		} else {
			showAll();
		}
	})();
</script>
</body>
</html>
