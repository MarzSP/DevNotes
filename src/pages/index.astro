---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import ThemeIcon from '../components/ThemeIcon.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const base = import.meta.env.BASE_URL;

function toArray(v: unknown): string[] {
	if (Array.isArray(v)) return v as string[];
	if (typeof v === 'string' && v) return [v];
	return [];
}

const allPosts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const recentPosts = allPosts.slice(0, 3).map((post) => {
	const d = post.data as unknown as Record<string, unknown>;
	const tags = toArray(d.tags).length ? toArray(d.tags) : toArray(d.theme);
	const firstTag = tags[0] ?? '';
	return { post, firstTag };
});
---

<!doctype html>
<html lang="en">
<head>
	<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	<style>
		body {
			margin: 0;
		}

		/* ── Hero ── */
		.hero {
			position: relative;
			padding: 7rem 2rem 6rem;
			text-align: center;
			overflow: hidden;
			background-color: #fff;
			background-image: radial-gradient(rgba(0, 0, 0, 0.07) 1px, transparent 1px);
			background-size: 24px 24px;
		}

		.hero::after {
			content: '';
			position: absolute;
			inset: 0;
			background: linear-gradient(to bottom, transparent 60%, #fff 100%);
			pointer-events: none;
		}

		.hero-inner {
			position: relative;
			z-index: 1;
			max-width: 760px;
			margin: 0 auto;
		}

		.hero-toggle {
			position: absolute;
			top: 1.25rem;
			right: 1.5rem;
			z-index: 2;
		}

		.hero-eyebrow {
			display: inline-flex;
			align-items: center;
			gap: 0.5rem;
			font-size: 0.75rem;
			font-weight: 600;
			text-transform: uppercase;
			letter-spacing: 0.12em;
			color: #ca8a04;
			margin-bottom: 1.5rem;
		}

		.hero-eyebrow span {
			display: inline-block;
			width: 24px;
			height: 1px;
			background: #ca8a04;
		}

		.hero-title {
			font-size: clamp(3rem, 8vw, 5.5rem);
			font-weight: 700;
			line-height: 1.05;
			letter-spacing: -0.03em;
			margin: 0 0 1.5rem;
			color: rgb(var(--black));
		}

		.hero-title .accent {
			background: linear-gradient(135deg, #ca8a04 0%, #0969da 100%);
			-webkit-background-clip: text;
			-webkit-text-fill-color: transparent;
			background-clip: text;
		}

		.hero-desc {
			font-size: 1.15rem;
			color: rgb(var(--gray));
			line-height: 1.65;
			max-width: 540px;
			margin: 0 auto 2.5rem;
		}

		.hero-actions {
			display: flex;
			align-items: center;
			justify-content: center;
			gap: 1rem;
		}

		.btn-primary {
			display: inline-flex;
			align-items: center;
			gap: 0.4rem;
			padding: 0.65rem 1.4rem;
			background: rgb(var(--black));
			color: #fff;
			font-size: 0.875rem;
			font-weight: 500;
			border-radius: 6px;
			text-decoration: none;
			transition: opacity 0.15s;
		}

		.btn-primary:hover {
			opacity: 0.8;
		}

		.btn-ghost {
			display: inline-flex;
			align-items: center;
			gap: 0.4rem;
			padding: 0.65rem 1.4rem;
			background: transparent;
			color: rgb(var(--gray));
			font-size: 0.875rem;
			font-weight: 500;
			border-radius: 6px;
			border: 1px solid rgb(var(--gray-light));
			text-decoration: none;
			transition: border-color 0.15s, color 0.15s;
		}

		.btn-ghost:hover {
			border-color: rgb(var(--gray));
			color: rgb(var(--black));
		}

		/* ── Recent posts ── */
		.recent {
			max-width: 1100px;
			margin: 0 auto;
			padding: 4rem 2rem 5rem;
		}

		.section-header {
			display: flex;
			align-items: baseline;
			justify-content: space-between;
			margin-bottom: 1.5rem;
			padding-bottom: 1rem;
			border-bottom: 1px solid rgb(var(--gray-light));
		}

		.section-title {
			font-size: 0.75rem;
			font-weight: 600;
			text-transform: uppercase;
			letter-spacing: 0.1em;
			color: rgb(var(--gray));
			margin: 0;
		}

		.section-link {
			font-size: 0.8rem;
			color: var(--accent);
			text-decoration: none;
			font-weight: 500;
		}

		.section-link:hover {
			text-decoration: underline;
		}

		.posts-grid {
			display: grid;
			grid-template-columns: repeat(3, 1fr);
			gap: 1px;
			background: rgb(var(--gray-light));
			border: 1px solid rgb(var(--gray-light));
			border-radius: 10px;
			overflow: hidden;
			list-style: none;
			margin: 0;
			padding: 0;
		}

		.post-card {
			background: #fff;
			padding: 1.5rem;
			display: flex;
			flex-direction: column;
			gap: 0.5rem;
			transition: background 0.15s;
		}

		.post-card a {
			text-decoration: none;
			display: flex;
			flex-direction: column;
			gap: 0.5rem;
			height: 100%;
		}

		.post-card:hover {
			background: #f6f8fa;
		}

		.post-meta {
			font-size: 0.75rem;
			color: #ca8a04;
		}

		.post-title {
			font-size: 1rem;
			font-weight: 600;
			color: rgb(var(--black));
			line-height: 1.35;
			margin: 0;
		}

		.post-card:hover .post-title {
			color: var(--accent);
		}

		.post-desc {
			font-size: 0.85rem;
			color: rgb(var(--gray));
			line-height: 1.5;
			margin: 0;
			display: -webkit-box;
			-webkit-line-clamp: 2;
			-webkit-box-orient: vertical;
			overflow: hidden;
		}

		/* ── Dark mode ── */
		html.dark .hero {
			background-color: #0d1117;
			background-image: radial-gradient(rgba(255, 255, 255, 0.05) 1px, transparent 1px);
		}

		html.dark .hero::after {
			background: linear-gradient(to bottom, transparent 60%, #0d1117 100%);
		}

		html.dark .hero-title {
			color: #f0f6fc;
		}

		html.dark .hero-desc {
			color: #7d8590;
		}

		html.dark .btn-primary {
			background: #f0f6fc;
			color: #0d1117;
		}

		html.dark .btn-ghost {
			border-color: #30363d;
			color: #7d8590;
		}

		html.dark .btn-ghost:hover {
			border-color: #7d8590;
			color: #e6edf3;
		}

		html.dark .section-header {
			border-bottom-color: #30363d;
		}

		html.dark .posts-grid {
			background: #30363d;
			border-color: #30363d;
		}

		html.dark .post-card {
			background: #0d1117;
		}

		html.dark .post-card:hover {
			background: #161b22;
		}

		html.dark .post-title {
			color: #e6edf3;
		}

		html.dark .post-card:hover .post-title {
			color: #58a6ff;
		}

		html.dark .post-meta {
			color: #fbbf24;
		}

		html.dark .recent {
			background: #0d1117;
		}

		@media (max-width: 720px) {
			.hero {
				padding: 5rem 1.5rem 4rem;
			}

			.hero-actions {
				flex-direction: column;
				align-items: stretch;
				max-width: 280px;
				margin: 0 auto;
			}

			.btn-primary, .btn-ghost {
				justify-content: center;
			}

			.posts-grid {
				grid-template-columns: 1fr;
			}

			.recent {
				padding: 3rem 1rem 4rem;
			}
		}
	</style>
</head>
<body>
	<!-- Hero -->
	<section class="hero">
		<div class="hero-toggle"><ThemeIcon /></div>
		<div class="hero-inner">
			<div class="hero-eyebrow">
				<span></span>
				Software Engineering
				<span></span>
			</div>
			<h1 class="hero-title">
				<em class="accent">Notes that<br />actually stick.</em>
			</h1>
			<p class="hero-desc">
				Architecture, patterns, and language features — explained clearly,
				with real code. No fluff, no padding.
			</p>
			<div class="hero-actions">
				<a href={`${base}blog/`} class="btn-primary">Read the blog →</a>
				<a href={`${base}about/`} class="btn-ghost">About me</a>
			</div>
		</div>
	</section>

	<!-- Recent posts -->
	<section class="recent">
		<div class="section-header">
			<p class="section-title">Latest posts</p>
			<a href={`${base}blog/`} class="section-link">View all →</a>
		</div>
		<ul class="posts-grid">
			{recentPosts.map(({ post, firstTag }) => (
				<li class="post-card">
					<a href={`${base}blog/${post.id}/`}>
						<div class="post-meta">
							<FormattedDate date={post.data.pubDate} />
							{firstTag && <> · {firstTag}</>}
						</div>
						<h2 class="post-title">{post.data.title}</h2>
						{post.data.description && <p class="post-desc">{post.data.description}</p>}
					</a>
				</li>
			))}
		</ul>
	</section>

	<Footer />
</body>
</html>
